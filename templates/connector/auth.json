{
  "strategy": "oauth2",
  "oauth2": {
    "authorizationUrl": "https://example.com/oauth/authorize",
    "tokenUrl": "https://example.com/oauth/token",
    "scopes": ["events.read", "events.write"],
    "clientIdEnvVar": "SP1_EXAMPLE_CLIENT_ID",
    "clientSecretEnvVar": "SP1_EXAMPLE_CLIENT_SECRET"
  }
}
