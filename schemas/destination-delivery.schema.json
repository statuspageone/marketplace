{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Destination Delivery",
  "type": "object",
  "required": ["destination_id", "http", "success_codes"],
  "properties": {
    "destination_id": { "type": "string" },
    "http": {
      "type": "object",
      "required": ["method", "url", "body_type", "body_template"],
      "properties": {
        "method": { "type": "string", "enum": ["POST", "PUT", "PATCH"] },
        "url": { "type": "string" },
        "headers": { "type": "object" },
        "body_type": { "type": "string", "enum": ["json", "form", "text"] },
        "body_template": { "type": "string" }
      }
    },
    "retry": {
      "type": "object",
      "properties": {
        "max_attempts": { "type": "integer" },
        "backoff_multiplier": { "type": "number" }
      }
    },
    "success_codes": {
      "type": "array",
      "items": { "type": "integer" }
    }
  }
}
