{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Webhook",
  "type": "object",
  "required": ["subscriptionUrl", "events", "fixturePath"],
  "properties": {
    "subscriptionUrl": { "type": "string" },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "header", "secretEnvVar"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["hmac-sha256", "hmac-sha1"] },
        "header": { "type": "string" },
        "secretEnvVar": { "type": "string" }
      }
    },
    "fixturePath": { "type": "string" }
  }
}
