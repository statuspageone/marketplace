{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Polling",
  "type": "object",
  "required": ["endpoint", "itemsPath", "cursorField", "pagination", "fixturePath"],
  "properties": {
    "endpoint": { "type": "string" },
    "itemsPath": { "type": "string" },
    "cursorField": { "type": "string" },
    "pagination": {
      "type": "object",
      "required": ["type", "nextCursorPath"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cursor", "page", "offset"]
        },
        "nextCursorPath": { "type": "string" }
      }
    },
    "fixturePath": { "type": "string" }
  }
}
