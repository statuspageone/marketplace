{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Polling",
  "type": "object",
  "required": ["endpoint", "pagination", "fixturePath"],
  "properties": {
    "endpoint": { "type": "string" },
    "method": { "type": "string", "enum": ["GET", "POST"] },
    "pagination": {
      "type": "object",
      "required": ["cursorField"],
      "properties": {
        "cursorField": { "type": "string" },
        "pageSize": { "type": "integer", "minimum": 1 }
      }
    },
    "backfill": {
      "type": "object",
      "required": ["supported"],
      "properties": {
        "supported": { "type": "boolean" },
        "maxLookbackDays": { "type": "integer", "minimum": 1 }
      }
    },
    "fixturePath": { "type": "string" }
  }
}
