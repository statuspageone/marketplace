{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Mapping",
  "type": "object",
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sourceEvent", "fieldMappings"],
        "properties": {
          "sourceEvent": { "type": "string" },
          "description": { "type": "string" },
          "fieldMappings": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": false,
            "properties": {
              "provider": { "$ref": "#/$defs/mappingValue" },
              "provider_event_type": { "$ref": "#/$defs/mappingValue" },
              "status": { "$ref": "#/$defs/mappingValue" },
              "severity": { "$ref": "#/$defs/mappingValue" },
              "title": { "$ref": "#/$defs/mappingValue" },
              "description": { "$ref": "#/$defs/mappingValue" },
              "resource_type": { "$ref": "#/$defs/mappingValue" },
              "resource_id": { "$ref": "#/$defs/mappingValue" },
              "resource_name": { "$ref": "#/$defs/mappingValue" },
              "service_name": { "$ref": "#/$defs/mappingValue" },
              "environment": { "$ref": "#/$defs/mappingValue" },
              "source_url": { "$ref": "#/$defs/mappingValue" },
              "occurred_at": { "$ref": "#/$defs/mappingValue" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "mappingValue": {
      "type": "object",
      "properties": {
        "sourcePath": { "type": "string" },
        "literal": { "type": "string" }
      },
      "oneOf": [
        { "required": ["sourcePath"] },
        { "required": ["literal"] }
      ]
    }
  }
}
