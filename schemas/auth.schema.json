{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "App Auth",
  "type": "object",
  "required": ["strategy"],
  "properties": {
    "strategy": {
      "type": "string",
      "enum": ["apiKey", "oauth", "bearer", "webhook_url", "none"]
    },
    "apiKey": {
      "type": "object",
      "required": ["headerName", "envVar"],
      "properties": {
        "headerName": { "type": "string" },
        "envVar": { "type": "string" }
      }
    },
    "oauth": {
      "type": "object",
      "required": ["authorizationUrl", "tokenUrl", "scopes", "clientIdEnvVar", "clientSecretEnvVar"],
      "properties": {
        "authorizationUrl": { "type": "string" },
        "tokenUrl": { "type": "string" },
        "scopes": { "type": "array", "items": { "type": "string" } },
        "clientIdEnvVar": { "type": "string" },
        "clientSecretEnvVar": { "type": "string" }
      }
    },
    "bearer": {
      "type": "object",
      "required": ["envVar"],
      "properties": {
        "envVar": { "type": "string" }
      }
    },
    "webhook_url": {
      "type": "object",
      "required": ["field", "label", "pattern"],
      "properties": {
        "field": { "type": "string" },
        "label": { "type": "string" },
        "pattern": { "type": "string" }
      }
    }
  }
}
