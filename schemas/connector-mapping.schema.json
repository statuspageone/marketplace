{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connector Mapping",
  "type": "object",
  "required": ["routes", "fields"],
  "properties": {
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sourceEvent", "canonicalRoute", "eventType"],
        "properties": {
          "sourceEvent": { "type": "string" },
          "canonicalRoute": { "type": "string" },
          "eventType": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sourcePath", "canonicalField"],
        "properties": {
          "sourcePath": { "type": "string" },
          "canonicalField": { "type": "string" }
        }
      }
    }
  }
}
