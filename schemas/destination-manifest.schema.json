{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Destination Manifest",
  "type": "object",
  "required": ["slug", "name", "description", "documentationUrl", "app_type", "version", "capabilities", "files"],
  "properties": {
    "slug": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "documentationUrl": { "type": "string" },
    "app_type": { "type": "string", "enum": ["destination"] },
    "version": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["webhook"] }
    },
    "files": {
      "type": "object",
      "required": ["auth", "destinations", "delivery"],
      "properties": {
        "auth": { "type": "string" },
        "destinations": { "type": "string" },
        "delivery": { "type": "string" }
      }
    }
  }
}
