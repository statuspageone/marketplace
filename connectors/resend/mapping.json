{
  "routes": [
    {
      "sourceEvent": "email.sent",
      "canonicalRoute": "request_log.created",
      "eventType": "request_log",
      "description": "Treat Resend send events as canonical request-log creation events."
    },
    {
      "sourceEvent": "email.delivered",
      "canonicalRoute": "request_log.updated",
      "eventType": "request_log",
      "description": "Track delivery updates against the same canonical request-log record."
    }
  ],
  "fields": [
    {
      "sourcePath": "data.id",
      "canonicalField": "request_log.id"
    },
    {
      "sourcePath": "data.created_at",
      "canonicalField": "request_log.created_at"
    },
    {
      "sourcePath": "data.to[0]",
      "canonicalField": "request_log.recipient"
    },
    {
      "sourcePath": "data.subject",
      "canonicalField": "request_log.subject"
    },
    {
      "sourcePath": "data.last_event",
      "canonicalField": "request_log.status"
    }
  ]
}
